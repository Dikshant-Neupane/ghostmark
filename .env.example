# Vercel KV — get from vercel.com > Storage > KV > your database > .env.local tab
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# GitHub API — get from github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# App URL
NEXT_PUBLIC_APP_URL=https://watermarkpdf.vercel.app
NEXT_PUBLIC_GITHUB_URL=https://github.com/Dikshant-Neupane/ghostmark
